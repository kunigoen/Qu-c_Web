@model ClinicWebsite_Team1.Models.schedule

@{
    ViewBag.Title = "Edit Schedule";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow">

                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Edit Schedule</h4>
                </div>

                <div class="card-body">

                    @using (Html.BeginForm())
                    {
                        @Html.HiddenFor(m => m.id)

                        <div class="mb-3">
                            <label class="form-label">Doctor</label>
                            @Html.DropDownListFor(m => m.doctor_id,
                                new SelectList(ViewBag.Doctors, "id", "id", Model.doctor_id),
                                new { @class = "form-select" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Room</label>
                            @Html.DropDownListFor(m => m.room_id,
                                new SelectList(ViewBag.Rooms, "id", "room_code", Model.room_id),
                                new { @class = "form-select" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Date</label>
                            @Html.TextBoxFor(m => m.work_date,
                                new
                                {
                                    @class = "form-control",
                                    type = "date",
                                    id = "work_date"
                                })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Start Time</label>
                            @Html.TextBoxFor(m => m.start_time,
                                new { @class = "form-control", type = "time" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">End Time</label>
                            @Html.TextBoxFor(m => m.end_time,
                                new { @class = "form-control", type = "time" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Max Patients</label>
                            @Html.TextBoxFor(m => m.max_patients,
                                new { @class = "form-control", type = "number" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            @Html.DropDownListFor(m => m.status,
                                new SelectList(new[] { "Available", "Full", "Closed" }, Model.status),
                                new { @class = "form-select" })
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-primary px-4">
                                Update
                            </button>

                            <a href="@Url.Action("Schedules")"
                               class="btn btn-secondary px-4">
                                Back
                            </a>
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>

<script>
    window.onload = function () {
        let today = new Date().toISOString().split('T')[0];
        document.getElementById("work_date").setAttribute("min", today);
    }
</script>