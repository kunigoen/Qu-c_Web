@model ClinicWebsite_Team1.Models.patient

@{
    ViewBag.Title = "Edit Patient";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Edit Patient</h4>
                </div>

                <div class="card-body">

                    @using (Html.BeginForm())
                    {
                        @Html.HiddenFor(m => m.id)

                        <div class="mb-3">
                            <label class="form-label">
                                Phone Number
                            </label>

                            @Html.TextBoxFor(
                                m => m.phone_number,
                                new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Gender
                            </label>

                            @Html.DropDownListFor(
                                m => m.gender,
                                new SelectList(
                                    new[] { "Male", "Female", "Other" },
                                    Model.gender),
                                new { @class = "form-select" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Address
                            </label>

                            @Html.TextAreaFor(
                                m => m.address,
                                new
                                {
                                    @class = "form-control",
                                    rows = 3
                                })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Blood Type
                            </label>

                            @Html.TextBoxFor(
                                m => m.blood_type,
                                new { @class = "form-control" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Emergency Contact
                            </label>

                            @Html.TextBoxFor(
                                m => m.emergency_contact,
                                new { @class = "form-control" })
                        </div>

                        <div class="text-center">
                            <button type="submit"
                                    class="btn btn-primary px-4">
                                Update
                            </button>

                            <a href="@Url.Action("Patients","Admin")"
                               class="btn btn-secondary px-4">
                                Back
                            </a>
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>