@model ClinicWebsite_Team1.Models.specialty

@{
    ViewBag.Title = "Edit Specialty";
}

<h2>Edit Specialty</h2>

@using (Html.BeginForm(
    "EditSpecialty",
    "Admin",
    FormMethod.Post,
    new { enctype = "multipart/form-data" }))
{
    @Html.HiddenFor(m => m.id)

    <div class="mb-3">
        <label>Name</label>

        @Html.TextBoxFor(
            m => m.name,
            new { @class = "form-control" })
    </div>

    <div class="mb-3">
        <label>Description</label>

        @Html.TextAreaFor(
            m => m.description,
            new { @class = "form-control", rows = 4 })
    </div>

    <div class="mb-3">
        <label>Current Image</label>
        <br />

        <img id="currentImage"
             src="@Url.Content("~/Content/images/" + Model.image_url)"
             width="200"
             class="img-thumbnail" />
    </div>

    <div class="mb-3">
        <label>Choose New Image</label>

        <input type="file"
               name="ImageFile"
               class="form-control"
               accept="image/*"
               onchange="previewImage(event)" />
    </div>

    <div class="mb-3">
        <label>Preview</label>
        <br />

        <img id="preview"
             src="@Url.Content("~/Content/images/" + Model.image_url)"
             width="200"
             class="img-thumbnail" />
    </div>

    <button type="submit"
            class="btn btn-primary">
        Save
    </button>

    <a href="@Url.Action("Specialties")"
       class="btn btn-secondary">
        Back
    </a>
}

<script>
    function previewImage(event) {

        var reader = new FileReader();

        reader.onload = function () {
            document.getElementById("preview").src =
                reader.result;
        };

        reader.readAsDataURL(event.target.files[0]);
    }
</script>