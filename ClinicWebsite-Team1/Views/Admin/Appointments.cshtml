@model IEnumerable<ClinicWebsite_Team1.Models.appointment>

@{
    ViewBag.Title = "Appointments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h4 class="mb-0">Manage Appointments</h4>
<div class="container mt-4">
    <div class="card shadow">
        <div class="card-body">

            <table class="table table-bordered table-hover text-center align-middle">

                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Symptoms</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.id</td>

                            <td>
                                @item.patient.user_account.full_name
                            </td>

                            <td>
                                @item.doctor.user_account.full_name
                            </td>

                            <td>
                                @item.schedule.work_date.ToString("yyyy-MM-dd")
                            </td>

                            <td>
                                @item.symptoms
                            </td>

                            <td>
                                @if (item.status_id == 1)
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                                else if (item.status_id == 2)
                                {
                                    <span class="badge bg-primary">Confirmed</span>
                                }
                                else if (item.status_id == 3)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                            </td>

                            <td>
                                <a class="btn btn-sm btn-warning"
                                   href="@Url.Action("UpdateAppointmentStatus", "Admin",new { id = item.id, statusId = 1 })">
                                    Pending
                                </a>
                                <a class="btn btn-sm btn-success"
                                   href="@Url.Action("UpdateAppointmentStatus", "Admin", new { id = item.id, statusId = 2 })">
                                    Confirm
                                </a>

                                <a class="btn btn-sm btn-primary"
                                   href="@Url.Action("UpdateAppointmentStatus", "Admin", new { id = item.id, statusId = 3 })">
                                    Complete
                                </a>

                                <a class="btn btn-sm btn-danger"
                                   href="@Url.Action("DeleteAppointment", "Admin", new { id = item.id })"
                                   onclick="return confirm('Are you sure you want to delete this appointment?');">
                                    Cancel
                                </a>

                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>