﻿@{
    ViewBag.Title = "Doctor Review";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var appointment = ViewBag.Appointment as ClinicWebsite_Team1.Models.appointment;
    var existedReview = ViewBag.ExistedReview as ClinicWebsite_Team1.Models.doctor_review;
}

<h2 class="mb-4 text-center">Doctor Review</h2>

@if (appointment != null)
{
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    Appointment Information
                </div>

                <div class="card-body">
                    <p><strong>Doctor:</strong> @appointment.doctor.user_account.full_name</p>
                    <p><strong>Specialty:</strong> @appointment.doctor.specialty.name</p>
                    <p><strong>Date:</strong> @appointment.schedule.work_date.ToString("dd/MM/yyyy")</p>
                    <p><strong>Status:</strong> @appointment.appointment_status.name</p>
                </div>
            </div>

            @if (existedReview != null)
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-success text-white">
                        Your Review
                    </div>

                    <div class="card-body">

                        <p>
                            <strong>Rating:</strong>
                            <span class="badge bg-warning text-dark px-3 py-2">
                                @existedReview.rating / 5
                            </span>
                        </p>

                        <p>
                            <strong>Comment:</strong>
                            @existedReview.comment
                        </p>

                        <p>
                            <strong>Review Date:</strong>
                            @(existedReview.review_date.HasValue ? existedReview.review_date.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")
                        </p>

                        <button type="button"
                                class="btn btn-warning"
                                data-bs-toggle="modal"
                                data-bs-target="#editReviewModal">
                            Edit Review
                        </button>

                        <a href="@Url.Action("MyAppointments", "Patient")"
                           class="btn btn-outline-secondary">
                            Back
                        </a>

                    </div>
                </div>

                <!-- EDIT REVIEW MODAL -->
                <div class="modal fade"
                     id="editReviewModal"
                     tabindex="-1"
                     aria-labelledby="editReviewModalLabel"
                     aria-hidden="true">

                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">

                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title" id="editReviewModalLabel">
                                    Edit Your Review
                                </h5>

                                <button type="button"
                                        class="btn-close"
                                        data-bs-dismiss="modal"
                                        aria-label="Close"></button>
                            </div>

                            <form method="post" action="@Url.Action("SubmitReview", "Patient")">
                                <div class="modal-body">

                                    <input type="hidden" name="appointmentId" value="@appointment.id" />

                                    <div class="mb-3">
                                        <label class="form-label">Rating</label>
                                        <select name="rating" class="form-select" required>
                                            <option value="">-- Select Rating --</option>
                                            <option value="5" @(existedReview.rating == 5 ? "selected" : "")>5 - Excellent</option>
                                            <option value="4" @(existedReview.rating == 4 ? "selected" : "")>4 - Good</option>
                                            <option value="3" @(existedReview.rating == 3 ? "selected" : "")>3 - Average</option>
                                            <option value="2" @(existedReview.rating == 2 ? "selected" : "")>2 - Poor</option>
                                            <option value="1" @(existedReview.rating == 1 ? "selected" : "")>1 - Very Poor</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Comment</label>
                                        <textarea name="comment"
                                                  class="form-control"
                                                  rows="4"
                                                  required>@existedReview.comment</textarea>
                                    </div>

                                    <small class="text-muted">
                                        Review date will be updated automatically after saving.
                                    </small>

                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="btn btn-outline-secondary"
                                            data-bs-dismiss="modal">
                                        Cancel
                                    </button>

                                    <button type="submit" class="btn btn-warning">
                                        Save Review
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-warning text-dark">
                        Rating & Comment
                    </div>

                    <div class="card-body">
                        <form method="post" action="@Url.Action("SubmitReview", "Patient")">
                            <input type="hidden" name="appointmentId" value="@appointment.id" />

                            <div class="mb-3">
                                <label class="form-label">Rating</label>
                                <select name="rating" class="form-select" required>
                                    <option value="">-- Select Rating --</option>
                                    <option value="5">5 - Excellent</option>
                                    <option value="4">4 - Good</option>
                                    <option value="3">3 - Average</option>
                                    <option value="2">2 - Poor</option>
                                    <option value="1">1 - Very Poor</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Comment</label>
                                <textarea name="comment"
                                          class="form-control"
                                          rows="4"
                                          required></textarea>
                            </div>

                            <small class="text-muted d-block mb-3">
                                Review date will be recorded automatically.
                            </small>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-warning">
                                    Submit Review
                                </button>

                                <a href="@Url.Action("MyAppointments", "Patient")"
                                   class="btn btn-outline-secondary">
                                    Back
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
}