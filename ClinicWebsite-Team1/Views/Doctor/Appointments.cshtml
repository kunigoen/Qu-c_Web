﻿@model List<ClinicWebsite_Team1.Models.appointment>

@{
    ViewBag.Title = "Appointments";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var statusList = ViewBag.StatusList as List<ClinicWebsite_Team1.Models.appointment_status>;
}

<h2 class="mb-4">Appointments</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get" action="@Url.Action("Appointments", "Doctor")" class="row g-3">

            <div class="col-md-4">
                <label class="form-label">Filter by Status</label>
                <select name="status" class="form-select">
                    <option value="">All Status</option>

                    @if (statusList != null)
                    {
                        foreach (var s in statusList)
                        {
                            <option value="@s.name" @(ViewBag.SelectedStatus == s.name ? "selected" : "")>
                                @s.name
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Filter by Date</label>
                <input type="date"
                       name="date"
                       class="form-control"
                       value="@(ViewBag.SelectedDate != null ? ((DateTime)ViewBag.SelectedDate).ToString("yyyy-MM-dd") : "")" />
            </div>

            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">
                    Filter
                </button>

                <a href="@Url.Action("Appointments", "Doctor")" class="btn btn-outline-secondary">
                    Reset
                </a>
            </div>

        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white">
        Appointment List
    </div>

    <div class="card-body">

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Symptoms</th>
                            <th>Status</th>
                            <th>Update Status</th>
                            <th>Patient Info</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusName = item.appointment_status.name;
                            var statusClass = "bg-secondary";

                            if (statusName == "Pending")
                            {
                                statusClass = "bg-warning text-dark";
                            }
                            else if (statusName == "Confirmed")
                            {
                                statusClass = "bg-primary";
                            }
                            else if (statusName == "Completed")
                            {
                                statusClass = "bg-success";
                            }
                            else if (statusName == "Cancelled")
                            {
                                statusClass = "bg-danger";
                            }

                            var modalId = "updateStatusModal_" + item.id;

                            <tr>
                                <td>@item.patient.user_account.full_name</td>

                                <td>@item.schedule.work_date.ToString("dd/MM/yyyy")</td>

                                <td>@item.schedule.start_time - @item.schedule.end_time</td>

                                <td>@item.symptoms</td>

                                <td>
                                    <span class="badge @statusClass px-3 py-2">
                                        @statusName
                                    </span>
                                </td>

                                <td>
                                    <button type="button"
                                            class="btn btn-sm btn-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#@modalId">
                                        Update
                                    </button>
                                </td>

                                <td>
                                    <a href="@Url.Action("PatientDetails", "Doctor", new { id = item.patient_id })"
                                       class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>
                                </td>
                            </tr>

                            <!-- UPDATE STATUS MODAL -->
                            <div class="modal fade"
                                 id="@modalId"
                                 tabindex="-1"
                                 aria-labelledby="@(modalId + "_Label")"
                                 aria-hidden="true">

                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">

                                        <div class="modal-header bg-primary text-white">
                                            <h5 class="modal-title" id="@(modalId + "_Label")">
                                                Update Appointment Status
                                            </h5>

                                            <button type="button"
                                                    class="btn-close btn-close-white"
                                                    data-bs-dismiss="modal"
                                                    aria-label="Close"></button>
                                        </div>

                                        <form method="post"
                                              action="@Url.Action("UpdateAppointmentStatus", "Doctor")">

                                            <div class="modal-body">

                                                <input type="hidden" name="appointmentId" value="@item.id" />

                                                <div class="mb-3">
                                                    <label class="form-label">Patient</label>
                                                    <input type="text"
                                                           class="form-control"
                                                           value="@item.patient.user_account.full_name"
                                                           readonly />
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Appointment Date</label>
                                                    <input type="text"
                                                           class="form-control"
                                                           value="@item.schedule.work_date.ToString("dd/MM/yyyy")"
                                                           readonly />
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Current Status</label>
                                                    <div>
                                                        <span class="badge @statusClass px-3 py-2">
                                                            @statusName
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">New Status</label>
                                                    <select name="statusId" class="form-select" required>
                                                        @if (statusList != null)
                                                        {
                                                            foreach (var s in statusList)
                                                            {
                                                                <option value="@s.id" @(item.status_id == s.id ? "selected" : "")>
                                                                    @s.name
                                                                </option>
                                                            }
                                                        }
                                                    </select>
                                                </div>

                                            </div>

                                            <div class="modal-footer">
                                                <button type="button"
                                                        class="btn btn-outline-secondary"
                                                        data-bs-dismiss="modal">
                                                    Cancel
                                                </button>

                                                <button type="submit" class="btn btn-primary">
                                                    Save Changes
                                                </button>
                                            </div>

                                        </form>

                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No appointments found.</p>
        }

    </div>
</div>