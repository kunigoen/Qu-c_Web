﻿@model List<ClinicWebsite_Team1.Models.schedule>

@{
    ViewBag.Title = "My Schedule";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var rooms = ViewBag.Rooms as List<ClinicWebsite_Team1.Models.clinic_room>;
}

<h2 class="mb-4">My Schedule</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Schedule List</h5>

    <button type="button"
            class="btn btn-success"
            data-bs-toggle="modal"
            data-bs-target="#addScheduleModal">
        + Add Schedule
    </button>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white">
        My Schedule Management
    </div>

    <div class="card-body">

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Room</th>
                            <th>Max</th>
                            <th>Booked</th>
                            <th>Available</th>
                            <th>Status</th>
                            <th style="width: 260px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            var booked = item.booked_patients ?? 0;
                            var available = item.max_patients - booked;

                            var statusClass = "bg-secondary";

                            if (item.status == "Available")
                            {
                                statusClass = "bg-success";
                            }
                            else if (item.status == "Full")
                            {
                                statusClass = "bg-danger";
                            }
                            else if (item.status == "Closed")
                            {
                                statusClass = "bg-dark";
                            }

                            var editModalId = "editScheduleModal_" + item.id;
                            var statusModalId = "statusScheduleModal_" + item.id;

                            <tr>
                                <td>@item.work_date.ToString("dd/MM/yyyy")</td>

                                <td>@item.start_time - @item.end_time</td>

                                <td>
                                    @(item.clinic_room != null ? item.clinic_room.room_code : "N/A")
                                </td>

                                <td>@item.max_patients</td>

                                <td>@booked</td>

                                <td>@available</td>

                                <td>
                                    <span class="badge @statusClass px-3 py-2">
                                        @item.status
                                    </span>
                                </td>

                                <td>
                                    <button type="button"
                                            class="btn btn-sm btn-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#@editModalId">
                                        Edit
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-warning"
                                            data-bs-toggle="modal"
                                            data-bs-target="#@statusModalId">
                                        Status
                                    </button>

                                    <form method="post"
                                          action="@Url.Action("DeleteSchedule", "Doctor")"
                                          class="d-inline"
                                          onsubmit="return confirm('Delete this schedule? If it already has appointments, it will be closed instead.');">

                                        <input type="hidden" name="id" value="@item.id" />

                                        <button type="submit" class="btn btn-sm btn-danger">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            <!-- EDIT SCHEDULE MODAL -->
                            <div class="modal fade"
                                 id="@editModalId"
                                 tabindex="-1"
                                 aria-labelledby="@(editModalId + "_Label")"
                                 aria-hidden="true">

                                <div class="modal-dialog modal-lg modal-dialog-centered">
                                    <div class="modal-content">

                                        <div class="modal-header bg-primary text-white">
                                            <h5 class="modal-title" id="@(editModalId + "_Label")">
                                                Edit Schedule
                                            </h5>

                                            <button type="button"
                                                    class="btn-close btn-close-white"
                                                    data-bs-dismiss="modal"
                                                    aria-label="Close"></button>
                                        </div>

                                        <form method="post" action="@Url.Action("EditSchedule", "Doctor")">
                                            <div class="modal-body">

                                                <input type="hidden" name="id" value="@item.id" />

                                                <div class="row g-3">

                                                    <div class="col-md-6">
                                                        <label class="form-label">Room</label>
                                                        <select name="roomId" class="form-select" required>
                                                            @if (rooms != null)
                                                            {
                                                                foreach (var r in rooms)
                                                                {
                                                                    <option value="@r.id" @(item.room_id == r.id ? "selected" : "")>
                                                                        @r.room_code
                                                                    </option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label">Work Date</label>
                                                        <input type="date"
                                                               name="workDate"
                                                               class="form-control"
                                                               value="@item.work_date.ToString("yyyy-MM-dd")"
                                                               required />
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label">Start Time</label>
                                                        <input type="time"
                                                               name="startTime"
                                                               class="form-control"
                                                               value="@item.start_time.ToString(@"hh\:mm")"
                                                               required />
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label">End Time</label>
                                                        <input type="time"
                                                               name="endTime"
                                                               class="form-control"
                                                               value="@item.end_time.ToString(@"hh\:mm")"
                                                               required />
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label">Max Patients</label>
                                                        <input type="number"
                                                               name="maxPatients"
                                                               class="form-control"
                                                               value="@item.max_patients"
                                                               min="@booked"
                                                               required />
                                                        <small class="text-muted">
                                                            Cannot be less than booked patients: @booked
                                                        </small>
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label">Status</label>
                                                        <select name="status" class="form-select">
                                                            <option value="Available" @(item.status == "Available" ? "selected" : "")>Available</option>
                                                            <option value="Full" @(item.status == "Full" ? "selected" : "")>Full</option>
                                                            <option value="Closed" @(item.status == "Closed" ? "selected" : "")>Closed</option>
                                                        </select>
                                                    </div>

                                                </div>

                                            </div>

                                            <div class="modal-footer">
                                                <button type="button"
                                                        class="btn btn-outline-secondary"
                                                        data-bs-dismiss="modal">
                                                    Cancel
                                                </button>

                                                <button type="submit" class="btn btn-primary">
                                                    Save Changes
                                                </button>
                                            </div>
                                        </form>

                                    </div>
                                </div>
                            </div>

                            <!-- UPDATE STATUS MODAL -->
                            <div class="modal fade"
                                 id="@statusModalId"
                                 tabindex="-1"
                                 aria-labelledby="@(statusModalId + "_Label")"
                                 aria-hidden="true">

                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">

                                        <div class="modal-header bg-warning text-dark">
                                            <h5 class="modal-title" id="@(statusModalId + "_Label")">
                                                Update Availability Status
                                            </h5>

                                            <button type="button"
                                                    class="btn-close"
                                                    data-bs-dismiss="modal"
                                                    aria-label="Close"></button>
                                        </div>

                                        <form method="post" action="@Url.Action("UpdateScheduleStatus", "Doctor")">
                                            <div class="modal-body">

                                                <input type="hidden" name="id" value="@item.id" />

                                                <p>
                                                    <strong>Date:</strong>
                                                    @item.work_date.ToString("dd/MM/yyyy")
                                                </p>

                                                <p>
                                                    <strong>Time:</strong>
                                                    @item.start_time - @item.end_time
                                                </p>

                                                <p>
                                                    <strong>Booked:</strong>
                                                    @booked / @item.max_patients
                                                </p>

                                                <div class="mb-3">
                                                    <label class="form-label">New Status</label>
                                                    <select name="status" class="form-select" required>
                                                        <option value="Available" @(item.status == "Available" ? "selected" : "")>Available</option>
                                                        <option value="Full" @(item.status == "Full" ? "selected" : "")>Full</option>
                                                        <option value="Closed" @(item.status == "Closed" ? "selected" : "")>Closed</option>
                                                    </select>
                                                </div>

                                            </div>

                                            <div class="modal-footer">
                                                <button type="button"
                                                        class="btn btn-outline-secondary"
                                                        data-bs-dismiss="modal">
                                                    Cancel
                                                </button>

                                                <button type="submit" class="btn btn-warning">
                                                    Update Status
                                                </button>
                                            </div>
                                        </form>

                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No schedule available.</p>
        }

    </div>
</div>


<!-- ADD SCHEDULE MODAL -->
<div class="modal fade"
     id="addScheduleModal"
     tabindex="-1"
     aria-labelledby="addScheduleModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="addScheduleModalLabel">
                    Add Schedule
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"
                        aria-label="Close"></button>
            </div>

            <form method="post" action="@Url.Action("AddSchedule", "Doctor")">
                <div class="modal-body">

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Room</label>
                            <select name="roomId" class="form-select" required>
                                <option value="">-- Select Room --</option>
                                @if (rooms != null)
                                {
                                    foreach (var r in rooms)
                                    {
                                        <option value="@r.id">@r.room_code</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Work Date</label>
                            <input type="date"
                                   name="workDate"
                                   class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Start Time</label>
                            <input type="time"
                                   name="startTime"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">End Time</label>
                            <input type="time"
                                   name="endTime"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Max Patients</label>
                            <input type="number"
                                   name="maxPatients"
                                   class="form-control"
                                   value="5"
                                   min="1"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select">
                                <option value="Available">Available</option>
                                <option value="Full">Full</option>
                                <option value="Closed">Closed</option>
                            </select>
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-success">
                        Add Schedule
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>