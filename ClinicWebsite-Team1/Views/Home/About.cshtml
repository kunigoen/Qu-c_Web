@model List<ClinicWebsite_Team1.Models.doctor>

@{
    ViewBag.Title = "Doctors";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="filter-bar shadow-sm p-3 mb-4 bg-white rounded">

    <div class="row align-items-center g-3">

        <!-- SEARCH (LEFT) -->
        <div class="col-md-6">
            <div class="input-group">

                <span class="input-group-text bg-white">
                    🔍
                </span>

                <input type="text"
                       id="searchBox"
                       class="form-control search-box"
                       placeholder="Search doctor by name..."
                       onkeyup="filterDoctors()">

            </div>
        </div>

        <!-- FILTER (RIGHT) -->
        <div class="col-md-6 d-flex justify-content-md-end">

            <select id="specialtyFilter"
                    class="form-select w-auto"
                    onchange="filterDoctors()">

                <option value="">All Specialties</option>

                @foreach (var s in Model
                    .Where(x => x.specialty != null)
                    .Select(x => x.specialty.name)
                    .Distinct())
                {
                    <option value="@s">@s</option>
                }

            </select>

        </div>

    </div>

</div>

<div class="row g-4" id="doctorContainer">

    @foreach (var d in Model)
    {
        <div class="col-md-4 doctor-item"
             data-name="@d.user_account.full_name.ToLower()"
             data-specialty="@d.specialty.name">

            <a href="@Url.Action("Details", "Home", new { id = d.id })"
               class="text-decoration-none text-dark">

                <div class="card doctor-card shadow-sm">

                    <img src="@Url.Content(d.image_url)"
                         class="card-img-top" />

                    <div class="card-body text-center">

                        <h5>@d.user_account.full_name</h5>

                        <p class="text-primary mb-1">
                            @d.specialty.name
                        </p>

                        <p class="small mb-1">
                            Experience: @d.experience_years years
                        </p>

                        <p class="fw-bold text-success mb-0">
                            Fee: @String.Format("{0:N0} đ", d.consultation_fee)
                        </p>

                    </div>

                </div>

            </a>
        </div>
    }
<div class="d-flex justify-content-center align-items-center gap-3 mt-4 mb-4">

    <!-- PREVIOUS -->
    <button id="prevBtn"
            class="btn btn-outline-secondary px-4"
            onclick="changePage(-1)">
        ← Previous
    </button>

    <!-- PAGE INDICATOR -->
    <div class="px-3 py-1 border rounded bg-light fw-semibold"
         id="pageIndicator">
        Page 1
    </div>

    <!-- NEXT -->
    <button id="nextBtn"
            class="btn btn-primary px-4"
            onclick="changePage(1)">
        Next →
    </button>

</div>  
</div>
<div class="text-center mt-4">

    <a href="@Url.Action("Index","Home")"
       class="btn btn-outline-primary btn-lg">
        Back to Home
    </a>

</div>
<script>

    let currentPage = 1;
    const itemsPerPage = 6;

    function getFilteredItems() {

        const search = document.getElementById("searchBox").value.toLowerCase();
        const specialty = document.getElementById("specialtyFilter").value;

        const items = document.querySelectorAll(".doctor-item");

        return Array.from(items).filter(item => {

            const name = item.dataset.name;
            const spec = item.dataset.specialty;

            const matchName = name.includes(search);
            const matchSpec = specialty === "" || spec === specialty;

            return matchName && matchSpec;
        });
    }

    function renderPage() {

        const items = getFilteredItems();

        const totalPages = Math.ceil(items.length / itemsPerPage);

        // fix page bounds
        if (currentPage > totalPages) currentPage = 1;
        if (currentPage < 1) currentPage = 1;

        // hide all first
        document.querySelectorAll(".doctor-item").forEach(x => {
            x.style.display = "none";
        });

        // show only current page items
        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;

        items.slice(start, end).forEach(x => {
            x.style.display = "block";
        });

        // update UI
        document.getElementById("prevBtn").disabled = currentPage === 1;
        document.getElementById("nextBtn").disabled = currentPage === totalPages || totalPages === 0;

        document.getElementById("pageIndicator").innerText =
            `Page ${totalPages === 0 ? 0 : currentPage} / ${totalPages}`;
    }

    function changePage(dir) {
        currentPage += dir;
        renderPage();
    }

    function filterDoctors() {
        currentPage = 1;
        renderPage();
    }

    window.onload = renderPage;

</script>
<style>
    .card-img-top {
        width: 100%;
        height: 300px;
        object-fit: contain; /* không cắt ảnh */
        object-position: center;
        background-color: #f8f9fa; /* nền để nhìn gọn */
        padding: 8px;
        object-position: top;
    }

    .doctor-item .card {
        transition: 0.3s;
        border-radius: 12px;
    }

        .doctor-item .card:hover {
            transform: translateY(-5px);
        }

    #searchBox, #specialtyFilter {
        border-radius: 10px;
    }
</style>