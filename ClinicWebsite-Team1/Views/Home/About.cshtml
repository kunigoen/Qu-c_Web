@using System.Linq
@model List<ClinicWebsite_Team1.Models.doctor>
@{
    ViewBag.Title = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="filter-bar shadow-sm p-3 mb-4 bg-white rounded">

    <div class="row align-items-center">

        <!-- SEARCH -->
        <div class="col-md-6">
            <input type="text"
                   id="searchBox"
                   class="form-control search-box"
                   placeholder="🔍 Search doctor by name..."
                   onkeyup="filterDoctors()">
        </div>

        <!-- FILTER -->
        <div class="col-md-6">
            <select id="specialtyFilter"
                    class="form-select"
                    onchange="filterDoctors()">
                <option value="">All Specialties</option>
                @foreach (var s in Model.Select(x => x.specialty.name).Distinct())
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>

    </div>
</div>
<div class="row g-4" id="doctorContainer">

    @foreach (var d in Model)
    {
        <div class="col-md-4 doctor-item"
             data-name="@d.user_account.full_name.ToLower()"
             data-specialty="@d.specialty.name">

            <a href="@Url.Action("Details", "Home", new { id = d.id })"
               class="text-decoration-none text-dark">

                <div class="card doctor-card shadow-sm">

                    <img src="@Url.Content(d.image_url)"
                         class="card-img-top" />

                    <div class="card-body text-center">

                        <h5>@d.user_account.full_name</h5>

                        <p class="text-primary mb-1">
                            @d.specialty.name
                        </p>

                        <p class="small mb-1">
                            Experience: @d.experience_years years
                        </p>

                        <p class="fw-bold text-success mb-0">
                            Fee: @String.Format("{0:N0} đ", d.consultation_fee)
                        </p>

                    </div>

                </div>

            </a>
        </div>
    }

</div>
<script>
    function renderDoctors() {
        const search = document.getElementById("searchBox").value.toLowerCase();
        const specialty = document.getElementById("specialtyFilter").value;

        const items = document.querySelectorAll(".doctor-item");

        let visibleItems = [];

        items.forEach(item => {
            const name = item.getAttribute("data-name");
            const spec = item.getAttribute("data-specialty");

            const matchSearch = name.includes(search);
            const matchSpec = specialty === "" || spec === specialty;

            if (matchSearch && matchSpec) {
                item.classList.remove("hidden");
                visibleItems.push(item);
            } else {
                item.classList.add("hidden");
            }
        });

        const totalPages = Math.ceil(visibleItems.length / itemsPerPage);

        visibleItems.forEach((item, index) => {
            if (index >= (currentPage - 1) * itemsPerPage &&
                index < currentPage * itemsPerPage) {
                item.classList.remove("hidden");
            } else {
                item.classList.add("hidden");
            }
        });

        document.getElementById("pageInfo").innerText =
            `Page ${currentPage} / ${totalPages || 1}`;
    }
    // init
    window.onload = renderDoctors;
</script>
<style>
    .card-img-top {
        width: 100%;
        height: 300px;
        object-fit: contain; /* không cắt ảnh */
        object-position: center;
        background-color: #f8f9fa; /* nền để nhìn gọn */
        padding: 8px;
        object-position: top;
    }

    .doctor-item .card {
        transition: 0.3s;
        border-radius: 12px;
    }

        .doctor-item .card:hover {
            transform: translateY(-5px);
        }

    #searchBox, #specialtyFilter {
        border-radius: 10px;
    }
</style>