@{
    Layout = null;
    ViewBag.Title = "Forgot Password";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #0f172a;
            font-family: Arial, sans-serif;
        }

        .card {
            width: 380px;
            background: #fff;
            padding: 35px;
            border-radius: 16px;
            text-align: center;
            box-shadow: 0 15px 35px rgba(0,0,0,.25);
        }

        h3 {
            color: #111827;
            margin-bottom: 10px;
            font-size: 28px;
        }

        .description {
            display: block;
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 25px;
        }

        .email-input {
            width: 100%;
            padding: 14px;
            border: 1px solid #d1d5db;
            border-radius: 30px;
            margin-bottom: 15px;
            font-size: 15px;
        }

            .email-input:focus {
                outline: none;
                border-color: #2563eb;
            }

        .btn-submit {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 30px;
            background: #2563eb;
            color: white;
            font-size: 15px;
            cursor: pointer;
            transition: .2s;
        }

            .btn-submit:hover {
                background: #1d4ed8;
            }
    </style>
</head>

<body>

    <div class="card">
        <h3>Forgot Password</h3>

        <span class="description">
            Enter your email to receive a verification code.
        </span>

        @using (Html.BeginForm("ForgotPassword", "Home", FormMethod.Post))
        {
            <input type="email"
                   name="email"
                   class="email-input"
                   placeholder="Enter your email"
                   required />

            <button type="submit" class="btn-submit">
                Send Code
            </button>
        }
    </div>

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Email Not Found',
                text: '@TempData["Error"]',
                confirmButtonText: 'OK'
            });
        </script>
    }

    @if (TempData["Success"] != null)
    {
        <script>
        Swal.fire({
            icon: 'success',
            title: 'Success',
            text: '@TempData["Success"]',
            confirmButtonText: 'Continue'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("VerifyCode", "Home")';
            }
        });
        </script>
    }

</body>
</html>