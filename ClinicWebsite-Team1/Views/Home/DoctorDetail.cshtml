@model ClinicWebsite_Team1.Models.doctor

@{
    ViewBag.Title = "Doctor Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var schedules = ViewBag.Schedules as List<ClinicWebsite_Team1.Models.schedule>;
    var reviews = ViewBag.Reviews as List<ClinicWebsite_Team1.Models.doctor_review>;
}
<div class="container my-4">

    <div class="card shadow-sm border-0 mb-4">

        <div class="row g-0">

            <div class="col-md-4">

                <img src="@Url.Content(Model.image_url)"
                     class="w-100"
                     style="height:350px;
                            object-fit:cover;
                            object-position:top;" />

            </div>

            <div class="col-md-8 p-4">

                <h2 class="fw-bold">
                    @Model.user_account.full_name
                </h2>

                <h5 class="text-primary mb-3">
                    @Model.specialty.name
                </h5>

                <p>
                    <b>Experience:</b> @Model.experience_years years
                </p>

                <p>
                    <b>Fee:</b>
                    @String.Format("{0:N0} đ", Model.consultation_fee)
                </p>

                <p class="text-muted">
                    @Model.biography
                </p>

                <a href="@Url.Action("Create","Appointment",
                         new { doctorId = Model.id })"
                   class="btn btn-success">
                    Book Appointment
                </a>

            </div>

        </div>

    </div>
    <h4 class="mb-3">Work Schedule</h4>

    <div class="row">

        @if (schedules != null && schedules.Any())
        {
            foreach (var s in schedules)
            {
                <div class="col-md-4 mb-3">

                    <div class="card shadow-sm border-0 h-100">

                        <div class="card-body">

                            <p class="mb-1">
                                <b>Date:</b> @s.work_date.ToString("dd/MM/yyyy")
                            </p>

                            <p class="mb-1">
                                <b>Time:</b> @s.start_time - @s.end_time
                            </p>

                            <p class="mb-1">
                                <b>Room:</b> @s.room_id
                            </p>

                            <p class="mb-0">
                                <b>Status:</b>

                                @if (s.status == "Available")
                                {
                                    <span class="badge bg-success">
                                        Available
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        @s.status
                                    </span>
                                }

                            </p>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <p class="text-muted">No schedule available.</p>
        }

    </div>
    <hr />

    <h4 class="mb-3">Patient Reviews</h4>

    @if (reviews != null && reviews.Any())
    {
        foreach (var r in reviews)
        {
            <div class="card border-0 shadow-sm mb-3">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div class="fw-bold">
                            ⭐ @r.rating / 5
                        </div>

                        <small class="text-muted">
                            @(r.review_date?.ToString("dd/MM/yyyy"))
                        </small>

                    </div>

                    <p class="mt-2 mb-0">
                        @r.comment
                    </p>

                </div>

            </div>
        }
    }
    else
    {
        <p class="text-muted">No reviews yet.</p>
    }

</div>
<style>

    .card img {
        border-radius: 0;
    }
</style>