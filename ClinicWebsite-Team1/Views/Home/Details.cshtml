@model ClinicWebsite_Team1.Models.doctor

@{
    var schedules = ViewBag.Schedules as List<ClinicWebsite_Team1.Models.schedule>;
    var reviews = ViewBag.Reviews as List<ClinicWebsite_Team1.Models.doctor_review>;

    ViewBag.Title = Model.user_account.full_name;
}

<div class="container py-5">

    <!-- PROFILE HEADER -->
    <div class="card border-0 shadow-lg mb-4">
        <div class="card-body p-4">

            <div class="row align-items-center">

                <div class="col-lg-3 text-center">

                    <img src="@Url.Content(Model.image_url)"
                         class="rounded-circle shadow"
                         style="width: 220px; height: 220px; object-fit: cover; object-position: top;" />

                </div>

                <div class="col-lg-6">

                    <h2 class="fw-bold mb-2">
                        @Model.user_account.full_name
                    </h2>

                    <h5 class="text-primary mb-3">
                        @Model.specialty.name
                    </h5>

                    <p class="mb-2">
                        <strong>Experience:</strong>
                        @Model.experience_years years
                    </p>

                    <p class="mb-2">
                        <strong>Phone:</strong>
                        @Model.user_account.phone_number
                    </p>

                    <p class="mb-0">
                        <strong>Consultation Fee:</strong>
                        @String.Format("{0:N0}", Model.consultation_fee) VND
                    </p>

                </div>

                <div class="col-lg-3 text-center">

                    <a href="@Url.Action("Create", "Appointment",
                    new { doctorId = Model.id })"
                       class="btn btn-success btn-lg w-100 mb-3">
                        Book Appointment
                    </a>

                    <div class="border rounded p-3 bg-light">

                        <h6 class="mb-1">Specialty</h6>
                        <p class="mb-0 text-primary">
                            @Model.specialty.name
                        </p>

                    </div>

                </div>

            </div>

        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="row">
        <!-- SCHEDULE -->
        <div class="col-12">

            <div class="card shadow-sm mb-4">

                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        Work Schedule
                    </h5>

                    <span class="badge bg-light text-dark">
                        @(schedules?.Count ?? 0) Schedule(s)
                    </span>
                </div>

                @if (schedules != null && schedules.Any())
                {
                    <div class="table-responsive">

                        <table class="table table-hover align-middle mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th class="text-center">Date</th>
                                    <th class="text-center">Time</th>
                                    <th class="text-center">Room</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var s in schedules)
                                {
                                    <tr>

                                        <td class="text-center">
                                            @s.work_date.ToString("dd/MM/yyyy")
                                        </td>

                                        <td class="text-center">
                                            @s.start_time - @s.end_time
                                        </td>

                                        <td class="text-center">
                                            Room @s.room_id
                                        </td>

                                        <td class="text-center">

                                            @if (s.status == "Available")
                                            {
                                                <span class="badge bg-success px-3 py-2">
                                                    Available
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary px-3 py-2">
                                                    @s.status
                                                </span>
                                            }

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>
                }
                else
                {
                    <div class="card-body">

                        <div class="alert alert-warning mb-0 text-center">
                            No schedule available.
                        </div>

                    </div>
                }

            </div>

        </div>

        <!-- REVIEWS -->
        <div class="card shadow-sm">

            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">
                    Patient Reviews
                </h5>
            </div>

            <div class="card-body">

                @if (reviews != null && reviews.Any())
                {
                    foreach (var r in reviews)
                    {
                        <div class="border-bottom mb-4 pb-3">

                            <div class="d-flex justify-content-between">

                                <div>

                                    @{
                                        for (int i = 0; i < r.rating; i++)
                                        {
                                            @:⭐
                                        }
                                    }

                                    <strong>
                                        (@r.rating/5)
                                    </strong>

                                </div>

                                <small class="text-muted">
                                    @(r.review_date?.ToString("dd/MM/yyyy"))
                                </small>

                            </div>

                            <p class="mt-3 mb-0">
                                @r.comment
                            </p>

                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        No reviews yet.
                    </div>
                }

            </div>

        </div>

        <div class="text-center mt-4">

            <a href="@Url.Action("About","Home")"
               class="btn btn-outline-primary btn-lg">
                Back 
            </a>

        </div>

    </div>