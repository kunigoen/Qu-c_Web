@model ClinicWebsite_Team1.Models.doctor

@{
    var schedules = ViewBag.Schedules as List<ClinicWebsite_Team1.Models.schedule>;
    var reviews = ViewBag.Reviews as List<ClinicWebsite_Team1.Models.doctor_review>;
    ViewBag.Title = Model.user_account.full_name + "- QK Hos";

}

<div class="container my-4">

    <!-- DOCTOR INFO -->
    <div class="card shadow-lg border-0 mb-4">

        <div class="row g-0">

            <div class="col-md-4">
                <img src="@Url.Content(Model.image_url)"
                     class="w-100"
                     style="height:350px; object-fit:cover;" />
            </div>

            <div class="col-md-8">
                <div class="card-body p-4">

                    <h3>@Model.user_account.full_name</h3>

                    <p class="text-primary">
                        @Model.specialty.name
                    </p>

                    <p>Experience: @Model.experience_years years</p>

                    <p>Fee: @String.Format("{0:N0} VND", Model.consultation_fee)</p>

                    <p>Phone: @Model.user_account.phone_number</p>

                    <a class="btn btn-success"
                       href="@Url.Action("Create", "Appointment", new { doctorId = Model.id })">
                        Book Appointment
                    </a>

                </div>
            </div>

        </div>
    </div>

    <!-- SCHEDULE -->
    <div class="card mb-4">

        <div class="card-header bg-primary text-white">
            Work Schedule
        </div>

        <div class="card-body">

            @if (schedules != null && schedules.Any())
            {
                <table class="table table-hover align-middle">

                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Room</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var s in schedules)
                        {
                            <tr>
                                <td>@s.work_date.ToString("dd/MM/yyyy")</td>
                                <td>@s.start_time - @s.end_time</td>
                                <td>@s.room_id</td>
                                <td><b>@s.status</b></td>
                            </tr>
                        }
                    </tbody>

                </table>
            }
            else
            {
                <p>No schedule available.</p>
            }

        </div>
    </div>

    <!-- REVIEWS -->
    <div class="card mb-4">

        <div class="card-header bg-success text-white">
            Patient Reviews
        </div>

        <div class="card-body">

            @if (reviews != null && reviews.Any())
            {
                foreach (var r in reviews)
                {
                    <div class="border-bottom pb-3 mb-3">

                        <div class="d-flex justify-content-between">

                            <div>
                                ⭐ <b>@r.rating / 5</b>
                            </div>

                            <small class="text-muted">
                                @(r.review_date?.ToString("dd/MM/yyyy"))
                            </small>

                        </div>

                        <p class="mt-2 mb-0">
                            @r.comment
                        </p>

                    </div>
                }
            }
            else
            {
                <p>No reviews yet.</p>
            }

        </div>
    </div>

    <!-- BACK BUTTON -->
    <div class="text-center mt-4">
        <a href="@Url.Action("Index","Home")"
           class="btn btn-outline-primary px-4">
            ← Back to Home
        </a>
    </div>

</div>